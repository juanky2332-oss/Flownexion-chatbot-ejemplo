# ─────────────────────────────────────────────────────────────
# ESGAS Chatbot — Variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NUNCA se sube a GitHub (está en .gitignore).
# En Vercel: Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Clave de OpenAI (GPT-4o). https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# API Webservice de Prestashop (solo se usa en server-side / /app/api/*)
# Si dejas PRESTASHOP_API_KEY vacía, el chatbot arranca en MODO DEMO con un
# catálogo de rodamientos de ejemplo (no necesita tienda real).
PRESTASHOP_API_KEY=TU_WS_KEY_DE_PRESTASHOP
PRESTASHOP_BASE_URL=https://b2b.esgas.es

# Fuerza el modo demo aunque haya ws_key configurada (1/true). Útil para probar.
PRESTASHOP_DEMO=

# Secreto compartido con priceinfo.php (subido a la raíz de Prestashop).
# DEBE ser idéntico al valor de PRICEINFO_SECRET dentro de priceinfo.php.
# Sin esto, el chatbot cae a un cálculo de descuento más limitado (specific_prices
# vía Webservice) que puede no reflejar reglas de precios de catálogo.
PRESTASHOP_PRICE_SECRET=

# ─── IDENTIDAD SEGURA (B2B) ──────────────────────────────────
# Secreto compartido para firmar tokens HMAC entre el módulo PS y este backend.
# DEBE ser idéntico al valor de NEXIONCHAT_HMAC_SECRET en el módulo de PrestaShop.
# Genera uno con: openssl rand -hex 32
# Si está vacío → modo demo sin autenticación (chatbot abierto, sin precios B2B).
HMAC_SECRET=

# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://b2b.esgas.es,http://localhost:3000

# Secreto interno para autenticar las llamadas server→server.
# Genera uno con: openssl rand -hex 32
INTERNAL_API_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# URL pública del despliegue (opcional, para llamadas internas absolutas).
# En Vercel se rellena sola con VERCEL_URL; en local usa http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
